# ============================================================
# B Smart Blogs — .gitignore
# !! Keep secrets & build artifacts out of version control !!
# ============================================================

# ----- Environment & Secrets (NEVER commit these) -----
.env
.env.*
!.env.example          # Allow the example template

# ----- Next.js Build Output -----
.next/
out/
build/

# ----- Node / Dependencies -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ----- Package manager locks (not committed — regenerate locally) -----
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----- TypeScript Build Cache -----
tsconfig.tsbuildinfo
*.tsbuildinfo

# ----- Testing -----
coverage/
.nyc_output/

# ----- Misc / Editor -----
.DS_Store
Thumbs.db
*.pem
*.log
*.local
.eslintcache
.cursor/

# ----- IDE / Editor Specific -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- Vercel -----
.vercel

# ----- Turbo -----
.turbo

# ----- Storybook -----
storybook-static/

# ----- Seed / Scripts output -----
scripts/*.log
scratch/
